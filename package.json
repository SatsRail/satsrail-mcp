{
  "name": "satsrail-mcp",
  "version": "1.2.0",
  "description": "Bitcoin Lightning payments for AI agents — MCP server for creating orders, invoices, and managing payments via SatsRail",
  "main": "src/index.js",
  "bin": {
    "satsrail-mcp": "src/index.js"
  },
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.js\" \"test/**/*.js\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "prettier": "^3.3.0",
    "vitest": "^2.1.0"
  },
  "files": [
    "src/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "bitcoin",
    "lightning",
    "lightning-network",
    "payments",
    "ai-agents",
    "ai-payments",
    "agent-commerce",
    "machine-to-machine",
    "micropayments",
    "non-custodial",
    "satsrail",
    "claude",
    "cursor",
    "windsurf",
    "llm",
    "checkout",
    "invoicing"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SatsRail/satsrail-mcp.git"
  },
  "homepage": "https://www.satsrail.com/developers/ai-agents",
  "engines": {
    "node": ">=18"
  }
}
